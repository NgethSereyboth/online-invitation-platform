# Application
HOST=0.0.0.0
PORT=8080
EINVITE_DATA_DIR=/var/lib/e-invitation-website
EINVITE_PUBLIC_BASE_URL=https://invite.example.com
EINVITE_ADMIN_EMAIL=admin@example.com
# Set to 1 only when commercial plan quotas should block new resources.
EINVITE_ENFORCE_PLAN_LIMITS=0

# Development only. Never expose auth tokens in production.
EINVITE_DEV_AUTH_TOKENS=0

# SMTP for email verification and password reset
EINVITE_MAIL_FROM=E-invitation-website <no-reply@example.com>
EINVITE_SMTP_HOST=smtp.example.com
EINVITE_SMTP_PORT=587
EINVITE_SMTP_USER=
EINVITE_SMTP_PASSWORD=
EINVITE_SMTP_TLS=1
EINVITE_SMTP_SSL=0

# Optional S3-compatible object storage / Cloudflare R2
EINVITE_OBJECT_STORAGE_BUCKET=
EINVITE_OBJECT_STORAGE_ENDPOINT=
EINVITE_OBJECT_STORAGE_REGION=auto
EINVITE_OBJECT_STORAGE_ACCESS_KEY=
EINVITE_OBJECT_STORAGE_SECRET_KEY=
EINVITE_OBJECT_STORAGE_PREFIX=materials
# Set this to a public CDN/custom-domain base URL when available. If omitted,
# the application proxies /uploads/* from the configured object-storage bucket.
EINVITE_OBJECT_STORAGE_PUBLIC_BASE_URL=
# Required for stable signed direct uploads across multiple application instances.
EINVITE_UPLOAD_SIGNING_SECRET=replace-with-a-long-random-secret


# Runtime database: leave empty for SQLite; set for PostgreSQL runtime.
EINVITE_DATABASE_URL=postgresql://user:password@host:5432/e_invitation_website

# Secure session cookies. Set Secure=1 behind HTTPS in production.
EINVITE_SESSION_COOKIE_NAME=einvite_session
EINVITE_COOKIE_SECURE=1

# Distributed rate limiting for multi-instance deployments.
EINVITE_REDIS_URL=redis://host:6379/0

# Optional external AI assistant provider. The endpoint should accept
# {task,prompt,context,model} and return text/output/output_text or an OpenAI-like choices payload.
EINVITE_AI_ENDPOINT=
EINVITE_AI_API_KEY=
EINVITE_AI_MODEL=
EINVITE_AI_TIMEOUT=20

# Provider-neutral signed subscription webhook.
EINVITE_BILLING_WEBHOOK_SECRET=

# Structured request logging for production log aggregation.
EINVITE_JSON_LOGS=1
# Optional hosted-checkout adapter. The endpoint receives userId/email/plan/returnUrl
# and must return an HTTPS checkout URL. Subscription changes arrive through the signed webhook above.
EINVITE_BILLING_CHECKOUT_ENDPOINT=
EINVITE_BILLING_API_KEY=
